# Copy this to .env and fill values (do NOT commit .env)

# Supabase credentials (backend only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_service_role_or_anon_key_here

# Optional cookies used by external AI proxies
RYNE_COOKIE=
WRITEHUMAN_COOKIE=

# Vite dev server proxy target inside docker
VITE_PROXY_TARGET=http://backend:8000
VITE_API_URL=http://backend:8000/api/v1
